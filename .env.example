# Copy this file to .env and fill in your Steam API key
# Get one free at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here
METRICS_TOKEN=choose_a_long_random_token

# Local Postgres config (used by docker-compose)
POSTGRES_DB=steamroulette
POSTGRES_USER=steamroulette
POSTGRES_PASSWORD=steamroulette_dev_password

# DB init job retry tuning
DB_INIT_MAX_RETRIES=30
DB_INIT_RETRY_DELAY_SECONDS=2
